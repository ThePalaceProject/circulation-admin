{
  "version": "1.8.2",
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2019",
    "outDir": "lib",
    "lib": ["es2023.array", "es2019", "dom"],
    "rootDir": ".",
    // Test-framework types (mocha, jest) are declared in tsconfig.mocha.json and
    // tsconfig.jest.json respectively, to prevent duplicate global declarations
    // between the two frameworks (TS2403: describe, it, test, beforeEach, etc.).
    "skipLibCheck": false,
    "esModuleInterop": true,
    "types": ["node"],
    "jsx": "react"
  },
  "exclude": [
    "lib",
    "node_modules",
    "tests/browser",
    // Test directories each have their own tsconfig (tsconfig.mocha.json /
    // tsconfig.jest.json) with the appropriate test-framework types.
    // Excluding here keeps the base compilation free of mocha/jest globals.
    "src/**/__tests__",
    "src/testHelper.ts",
    "tests/jest"
  ],
  "typedocOptions": {
    "entryPointStrategy": "expand",
    "out": "docs"
  }
}
