{
  "version": "1.8.2",
  "compilerOptions": {
    "module": "commonjs",
    "target": "es5",
    "outDir": "lib",
    "lib": ["es2023.array","es2019", "dom"],
    "rootDir": ".",
    // Some dependencies' type declarations (recharts, @open-draft/deferred-promise)
    // do not compile under this project's `target` and `esModuleInterop` settings.
    "skipLibCheck": true,
    "types": ["node", "jest", "@testing-library/jest-dom"],
    "jsx": "react"
  },
  "exclude": [
    "lib",
    "node_modules",
    "tests/browser"
  ],
  "typedocOptions": {
    "entryPointStrategy": "expand",
    "out": "docs"
  }
}
